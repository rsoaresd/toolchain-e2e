		if [[ -z ${TOOLCHAIN_CLUSTER_NAME} ]]; then \
			echo "ERROR: no ToolchainCluster for member 2 found"; \
			exit 1; \
		fi; \
		echo "TOOLCHAIN_CLUSTER_NAME ${TOOLCHAIN_CLUSTER_NAME}"; \
		echo "ENVIRONMENT e2e-tests"; \
		PATCH_FILE=/tmp/patch-toolchainconfig_14113232.json; \
		echo "{\"spec\":{\"members\":{\"specificPerMemberCluster\":{\"${TOOLCHAIN_CLUSTER_NAME}\":$(oc get toolchainconfig config -n toolchain-host-14113232 -o jsonpath='{.spec.members.default}' | jq '. += { webhook: { deploy: false } }')}}}}" > $PATCH_FILE; \
		oc patch toolchainconfig config -n toolchain-host-14113232 --type=merge --patch "$(cat $PATCH_FILE)"; \
	fi;
